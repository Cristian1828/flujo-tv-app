---
import { site, waLink } from '../../config/site';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const waHref = waLink('Hola, quiero instalar Flujo TV y necesito ayuda para elegir el dispositivo correcto.');

const pageTitle     = 'Descargas e Instalación Flujo TV | APK Android, Google TV y Android TV — Guías Oficiales 2026';
const pageDesc      = 'Descarga Flujo TV APK para Android o instala en Google TV y Android TV. Guías oficiales paso a paso con video, activación asegurada y soporte garantizado 24/7.';
const pageKeywords  = 'descargar Flujo TV, instalar Flujo TV, Flujo TV APK Android, descargar apk Flujo TV, Flujo TV Android TV, Flujo TV Google TV, guia instalacion Flujo TV, como instalar Flujo TV, Flujo TV movil, Flujo TV celular Android, tutorial Flujo TV, manual instalacion Flujo TV 2026';
const canonical     = `${site.canonical}/descargas/`;

// Dispositivos activos
const devices = [
  {
    id: 'android-tv',
    slug: '/descargas/android-tv',
    icon: 'android',
    label: 'Android TV',
    badge: '',
    badgeColor: '',
    description: 'Televisores y dispositivos con sistema operativo Android TV. Instalación completa en menos de 5 minutos con código Downloader.',
    difficulty: 'Fácil',
    time: '~5 min',
    available: true,
  },
  {
    id: 'google-tv',
    slug: '/descargas/google-tv',
    icon: 'google-tv',
    label: 'Google TV',
    badge: 'Nuevo',
    badgeColor: 'bg-emerald-500 text-white',
    description: 'Chromecast con Google TV, televisores con Google TV integrado (Sony, TCL, Hisense). Guía actualizada 2026.',
    difficulty: 'Fácil',
    time: '~5 min',
    available: true,
  },

  // ──────────────────────────────────────────────────────────────
  // ──────────────────────────────────────────────────────────────
  // ANDROID MÓVIL/TABLET — descarga APK directa
  {
    id: 'android-movil',
    slug: site.download.mobileApkHref,
    icon: 'android-phone',
    label: 'Android Móvil / Tablet',
    badge: 'Descarga APK',
    badgeColor: 'bg-orange-500 text-white',
    description: 'Smartphones y tablets Android. Descarga directa del archivo APK oficial. Compatible con Android 5.0+.',
    difficulty: 'Fácil',
    time: '2 min',
    available: true,
    directDownload: true,
  },

  // FIRE STICK — PRÓXIMAMENTE (dejar comentado)
  // {
  //   id: 'fire-stick',
  //   slug: '/descargas/fire-stick',
  //   icon: 'fire',
  //   label: 'Fire Stick / Fire TV',
  //   badge: 'Próximamente',
  //   badgeColor: 'bg-amber-500 text-white',
  //   description: 'Amazon Fire Stick (1ª, 2ª y 3ª generación), Fire TV Cube y Fire TV Stick 4K. Guía con habilitación de fuentes desconocidas.',
  //   difficulty: 'Intermedio',
  //   time: '~10 min',
  //   available: false,
  // },
  // ──────────────────────────────────────────────────────────────
];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: site.canonical },
    { '@type': 'ListItem', position: 2, name: 'Descargas', item: canonical },
  ],
};

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: pageTitle,
  description: pageDesc,
  url: canonical,
  inLanguage: 'es',
  isPartOf: { '@type': 'WebSite', url: site.canonical },
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: breadcrumbSchema.itemListElement,
  },
};
---

<Layout title={pageTitle} description={pageDesc} keywords={pageKeywords}>
  <!-- Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} slot="head" />
  <link rel="canonical" href={canonical} slot="head" />

  <Header />

  <main class="min-h-screen bg-gradient-to-b from-slate-50 to-white pt-24 pb-20">

    <!-- ── Breadcrumb ───────────────────────────────────────────── -->
    <nav aria-label="Ruta de navegación" class="mx-auto max-w-6xl px-4 mb-6">
      <ol class="flex items-center gap-2 text-sm text-slate-900/55">
        <li><a href="/" class="hover:text-slate-900 transition">Inicio</a></li>
        <li aria-hidden="true"><span class="select-none">›</span></li>
        <li class="text-slate-900 font-medium" aria-current="page">Descargas</li>
      </ol>
    </nav>

    <!-- ── Hero ─────────────────────────────────────────────────── -->
    <section class="mx-auto max-w-6xl px-4 mb-14">
      <div class="rounded-[2.5rem] bg-slate-900 overflow-hidden relative">
        <!-- glow decorations -->
        <div class="absolute -top-24 -left-24 h-72 w-72 rounded-full bg-orange-500/20 blur-3xl pointer-events-none" aria-hidden="true"></div>
        <div class="absolute -bottom-24 -right-24 h-72 w-72 rounded-full bg-sky-500/15 blur-3xl pointer-events-none" aria-hidden="true"></div>

        <div class="relative z-10 px-8 py-14 sm:px-14 sm:py-16 flex flex-col lg:flex-row items-center gap-10">
          <!-- text -->
          <div class="flex-1 text-center lg:text-left">
            <div class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-white/80 mb-5">
              <span class="h-1.5 w-1.5 rounded-full bg-orange-400 animate-pulse"></span>
              Guías oficiales de instalación
            </div>
            <h1 class="text-3xl sm:text-4xl lg:text-5xl font-black tracking-tight text-white leading-[1.08]">
              Instala <span class="text-orange-400">Flujo TV</span><br class="hidden sm:block" /> en tu dispositivo
            </h1>
            <p class="mt-4 max-w-2xl text-white/70 text-base sm:text-lg leading-relaxed">
              Guías paso a paso para cada dispositivo compatible. Sin conocimientos técnicos. En minutos ya estarás viendo contenido.
            </p>
            <div class="mt-8 flex flex-wrap justify-center lg:justify-start gap-3">
              <a
                href={waHref}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 rounded-xl bg-orange-500 hover:bg-orange-400 px-6 py-3 text-sm font-bold text-white transition shadow-lg shadow-orange-500/30"
              >
                <!-- whatsapp icon -->
                <svg viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4" aria-hidden="true">
                  <path d="M20.52 3.48A11.89 11.89 0 0 0 12.07 0C5.5 0 .16 5.33.16 11.9c0 2.1.55 4.16 1.6 5.97L0 24l6.31-1.65a11.9 11.9 0 0 0 5.76 1.47h.01c6.57 0 11.9-5.33 11.9-11.9 0-3.18-1.24-6.17-3.46-8.44Zm-8.45 18.3h-.01a9.87 9.87 0 0 1-5.04-1.38l-.36-.22-3.74.98 1-3.65-.24-.38a9.86 9.86 0 0 1-1.5-5.26c0-5.45 4.44-9.88 9.9-9.88a9.82 9.82 0 0 1 7 2.9 9.82 9.82 0 0 1 2.9 7c0 5.45-4.44 9.89-9.88 9.89Z"/>
                </svg>
                Necesito ayuda con la instalación
              </a>
              <a
                href="/#planes"
                class="inline-flex items-center gap-2 rounded-xl border border-white/20 bg-white/10 hover:bg-white/15 px-6 py-3 text-sm font-semibold text-white transition"
              >
                Ver planes y precios
              </a>
            </div>
          </div>

          <!-- stats -->
          <div class="grid grid-cols-3 lg:grid-cols-1 gap-3 shrink-0 lg:min-w-[160px]">
            {[
              { v: '+3K', l: 'Canales' },
              { v: '4K', l: 'Calidad' },
              { v: '5 min', l: 'Instalación' },
            ].map(s => (
              <div class="rounded-2xl border border-white/10 bg-white/8 px-4 py-3 text-center">
                <div class="text-xl sm:text-2xl font-black text-orange-400">{s.v}</div>
                <div class="text-[11px] uppercase tracking-wider text-white/55 mt-0.5">{s.l}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ── Device Cards ──────────────────────────────────────────── -->
    <section class="mx-auto max-w-6xl px-4 mb-16" aria-labelledby="devices-heading">
      <h2 id="devices-heading" class="text-2xl sm:text-3xl font-black text-slate-900 tracking-tight mb-2">
        Elige tu dispositivo
      </h2>
      <p class="text-slate-900/60 mb-10 max-w-2xl">
        Selecciona el dispositivo donde instalarás Flujo TV y accede a la guía específica con video y pasos detallados.
      </p>

      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">

        {/* Android TV card */}
        <a
          href="/descargas/android-tv"
          class="group relative flex flex-col rounded-[2rem] border border-slate-900/10 bg-white shadow-soft hover:shadow-lg hover:-translate-y-1 transition-all duration-300 overflow-hidden focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange-400"
          aria-label="Guía de instalación para Android TV"
        >
          <!-- top accent bar -->
          <div class="h-1.5 w-full bg-gradient-to-r from-[#3DDC84] to-[#0f9d58]"></div>
          <div class="flex flex-col flex-1 p-6">
            <!-- icon -->
            <div class="mb-5 flex items-center justify-between">
              <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-[#3DDC84]/10 border border-[#3DDC84]/20">
                <svg viewBox="0 0 24 24" fill="none" class="h-8 w-8" aria-hidden="true">
                  <path d="M17.523 15.341a.5.5 0 0 0 .5-.5c0-.277-.223-.5-.5-.5H6.477a.5.5 0 0 0 0 1h11.046ZM4.5 6.5h15C20.88 6.5 22 7.62 22 8.899v5.202C22 15.38 20.88 16.5 19.5 16.5h-15C3.12 16.5 2 15.38 2 14.101V8.9C2 7.619 3.12 6.5 4.5 6.5Z" fill="#3DDC84"/>
                  <!-- Android robot head simplified -->
                  <circle cx="9" cy="11.5" r="1" fill="#0f9d58"/>
                  <circle cx="15" cy="11.5" r="1" fill="#0f9d58"/>
                </svg>
              </div>
              <span class="text-xs font-bold text-slate-900/40 uppercase tracking-wider">Android TV</span>
            </div>

            <h3 class="text-xl font-extrabold text-slate-900 leading-tight group-hover:text-[#0f9d58] transition">
              Android TV
            </h3>
            <p class="mt-2 text-sm text-slate-900/60 leading-relaxed flex-1">
              Televisores y dispositivos con sistema operativo Android TV. Instalación completa en menos de 5 minutos con código Downloader.
            </p>

            <div class="mt-5 flex items-center justify-between">
              <div class="flex gap-4">
                <div class="text-center">
                  <div class="text-xs font-black text-slate-900">Fácil</div>
                  <div class="text-[10px] text-slate-900/45 uppercase tracking-wide">Dificultad</div>
                </div>
                <div class="text-center">
                  <div class="text-xs font-black text-slate-900">~5 min</div>
                  <div class="text-[10px] text-slate-900/45 uppercase tracking-wide">Tiempo</div>
                </div>
              </div>
              <div class="flex items-center gap-1.5 text-sm font-bold text-[#0f9d58] group-hover:gap-2.5 transition-all">
                Ver guía
                <svg viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4" aria-hidden="true"><path d="M7 5l5 5-5 5" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
            </div>
          </div>
        </a>

        {/* Google TV card */}
        <a
          href="/descargas/google-tv"
          class="group relative flex flex-col rounded-[2rem] border border-slate-900/10 bg-white shadow-soft hover:shadow-lg hover:-translate-y-1 transition-all duration-300 overflow-hidden focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange-400"
          aria-label="Guía de instalación para Google TV"
        >
          <div class="h-1.5 w-full bg-gradient-to-r from-[#4285F4] via-[#EA4335] to-[#FBBC04]"></div>
          <div class="flex flex-col flex-1 p-6">
            <div class="mb-5 flex items-center justify-between">
              <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-[#4285F4]/10 border border-[#4285F4]/20">
                <svg viewBox="0 0 24 24" class="h-8 w-8" aria-hidden="true">
                  <circle cx="12" cy="12" r="10" fill="#4285F4"/>
                  <path d="M7 12h10M12 7c-2.76 0-5 2.24-5 5s2.24 5 5 5 5-2.24 5-5" stroke="white" stroke-width="1.5" fill="none" stroke-linecap="round"/>
                </svg>
              </div>
              <div class="flex items-center gap-2">
                <span class="rounded-full bg-emerald-500 text-white text-[10px] font-bold px-2 py-0.5 uppercase tracking-wide">Nuevo</span>
                <span class="text-xs font-bold text-slate-900/40 uppercase tracking-wider">Google TV</span>
              </div>
            </div>

            <h3 class="text-xl font-extrabold text-slate-900 leading-tight group-hover:text-[#4285F4] transition">
              Google TV
            </h3>
            <p class="mt-2 text-sm text-slate-900/60 leading-relaxed flex-1">
              Chromecast con Google TV, televisores Sony, TCL, Hisense con Google TV integrado. Guía actualizada 2026.
            </p>

            <div class="mt-5 flex items-center justify-between">
              <div class="flex gap-4">
                <div class="text-center">
                  <div class="text-xs font-black text-slate-900">Fácil</div>
                  <div class="text-[10px] text-slate-900/45 uppercase tracking-wide">Dificultad</div>
                </div>
                <div class="text-center">
                  <div class="text-xs font-black text-slate-900">~5 min</div>
                  <div class="text-[10px] text-slate-900/45 uppercase tracking-wide">Tiempo</div>
                </div>
              </div>
              <div class="flex items-center gap-1.5 text-sm font-bold text-[#4285F4] group-hover:gap-2.5 transition-all">
                Ver guía
                <svg viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4" aria-hidden="true"><path d="M7 5l5 5-5 5" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
            </div>
          </div>
        </a>

        {/* Android Móvil / Tablet card — descarga APK directa */}
        <div
          class="group relative flex flex-col rounded-[2rem] border border-orange-500/25 bg-white shadow-soft hover:shadow-lg hover:-translate-y-1 transition-all duration-300 overflow-hidden"
          aria-label="Descargar APK Flujo TV para Android móvil"
        >
          <div class="h-1.5 w-full bg-gradient-to-r from-orange-500 to-orange-400"></div>
          <div class="flex flex-col flex-1 p-6">
            <div class="mb-5 flex items-center justify-between">
              <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-orange-500/10 border border-orange-500/20">
                <!-- Phone icon -->
                <svg viewBox="0 0 24 24" fill="none" class="h-8 w-8" aria-hidden="true">
                  <rect x="5" y="2" width="14" height="20" rx="3" stroke="#f97316" stroke-width="1.8" fill="none"/>
                  <circle cx="12" cy="18.5" r="1" fill="#f97316"/>
                  <path d="M9 5.5h6" stroke="#f97316" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              </div>
              <div class="flex items-center gap-2">
                <span class="rounded-full bg-orange-500 text-white text-[10px] font-bold px-2 py-0.5 uppercase tracking-wide">Descarga APK</span>
                <span class="text-xs font-bold text-slate-900/40 uppercase tracking-wider">Android</span>
              </div>
            </div>

            <h3 class="text-xl font-extrabold text-slate-900 leading-tight group-hover:text-orange-500 transition">
              Android Móvil / Tablet
            </h3>
            <p class="mt-2 text-sm text-slate-900/60 leading-relaxed flex-1">
              Smartphones y tablets Android 5.0+. Descarga directa del APK oficial. Sin intermediarios, instalación en menos de 2 minutos.
            </p>

            <div class="mt-5 flex items-center justify-between">
              <div class="flex gap-4">
                <div class="text-center">
                  <div class="text-xs font-black text-slate-900">Fácil</div>
                  <div class="text-[10px] text-slate-900/45 uppercase tracking-wide">Dificultad</div>
                </div>
                <div class="text-center">
                  <div class="text-xs font-black text-slate-900">~2 min</div>
                  <div class="text-[10px] text-slate-900/45 uppercase tracking-wide">Tiempo</div>
                </div>
              </div>
              <a
                href={site.download.mobileApkHref}
                download
                class="inline-flex items-center gap-1.5 rounded-xl bg-orange-500 hover:bg-orange-400 px-4 py-2 text-xs font-bold text-white transition shadow-md shadow-orange-500/25"
              >
                <svg viewBox="0 0 20 20" fill="currentColor" class="h-3.5 w-3.5" aria-hidden="true"><path fill-rule="evenodd" d="M10 3a.75.75 0 0 1 .75.75v7.44l2.72-2.72a.75.75 0 1 1 1.06 1.06l-4 4a.75.75 0 0 1-1.06 0l-4-4a.75.75 0 1 1 1.06-1.06L9.25 11.19V3.75A.75.75 0 0 1 10 3ZM3.75 15a.75.75 0 0 0 0 1.5h12.5a.75.75 0 0 0 0-1.5H3.75Z" clip-rule="evenodd"/></svg>
                Descargar APK
              </a>
            </div>
          </div>
        </div>

        {/*
          ──────────────────────────────────────────────────────────
          FIRE STICK — PRÓXIMAMENTE (tarjeta comentada)
          ──────────────────────────────────────────────────────────

          <div class="relative flex flex-col rounded-[2rem] border border-slate-900/10 bg-white/60 shadow-soft overflow-hidden opacity-70 cursor-not-allowed select-none" aria-label="Guía Fire Stick - Próximamente">
            <div class="h-1.5 w-full bg-gradient-to-r from-[#FF9900] to-[#FF6900]"></div>
            <div class="flex flex-col flex-1 p-6">
              <div class="mb-5 flex items-center justify-between">
                <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-[#FF9900]/10 border border-[#FF9900]/20">
                  <svg viewBox="0 0 24 24" class="h-8 w-8" fill="none" aria-hidden="true">
                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-2-9l5 3-5 3V11z" fill="#FF9900"/>
                  </svg>
                </div>
                <span class="rounded-full bg-amber-500 text-white text-[10px] font-bold px-2 py-0.5 uppercase tracking-wide">Próximamente</span>
              </div>
              <h3 class="text-xl font-extrabold text-slate-900">Fire Stick / Fire TV</h3>
              <p class="mt-2 text-sm text-slate-900/50 leading-relaxed flex-1">
                Amazon Fire Stick (todas las generaciones), Fire TV Cube y Fire TV Stick 4K. Incluye habilitación de fuentes desconocidas.
              </p>
              <div class="mt-5 flex items-center justify-between">
                <div class="flex gap-4">
                  <div class="text-center">
                    <div class="text-xs font-black text-slate-900/50">Intermedio</div>
                    <div class="text-[10px] text-slate-900/35 uppercase tracking-wide">Dificultad</div>
                  </div>
                  <div class="text-center">
                    <div class="text-xs font-black text-slate-900/50">~10 min</div>
                    <div class="text-[10px] text-slate-900/35 uppercase tracking-wide">Tiempo</div>
                  </div>
                </div>
                <div class="text-xs text-slate-900/35 font-semibold uppercase tracking-wide">Muy pronto</div>
              </div>
            </div>
          </div>

          ──────────────────────────────────────────────────────────
        */}

      </div>
    </section>

    <!-- ── Info strip ───────────────────────────────────────────── -->
    <section class="mx-auto max-w-6xl px-4 mb-12">
      <div class="rounded-[2rem] border border-slate-900/8 bg-slate-50 px-8 py-8">
        <h2 class="text-lg font-extrabold text-slate-900 mb-6">¿Tienes dudas antes de instalar?</h2>
        <div class="grid gap-4 sm:grid-cols-3">
          {[
            {
              icon: '📶',
              title: 'Verifica tu internet',
              desc: 'Necesitas mínimo 10 Mbps para HD y 20–30 Mbps para 4K. Conexión por cable mejora la estabilidad.',
            },
            {
              icon: '📱',
              title: 'Solo Android',
              desc: 'Flujo TV es exclusivo para Android. TV Box, Fire Stick, Google TV, Xiaomi Stick y móviles Android.',
            },
            {
              icon: '💬',
              title: 'Soporte 24/7',
              desc: 'Si tienes algún problema durante la instalación, responde por WhatsApp en minutos.',
            },
          ].map(item => (
            <div class="flex gap-4">
              <span class="text-2xl shrink-0 mt-0.5">{item.icon}</span>
              <div>
                <div class="font-extrabold text-slate-900 text-sm">{item.title}</div>
                <p class="mt-1 text-sm text-slate-900/60 leading-relaxed">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── CTA final ─────────────────────────────────────────────── -->
    <section class="mx-auto max-w-6xl px-4 text-center">
      <p class="text-slate-900/55 text-sm mb-3">¿Prefieres que te ayudemos directamente?</p>
      <a
        href={waHref}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-xl bg-emerald-600 hover:bg-emerald-500 px-7 py-3 text-sm font-bold text-white transition shadow-lg shadow-emerald-600/25"
      >
        <svg viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4" aria-hidden="true">
          <path d="M20.52 3.48A11.89 11.89 0 0 0 12.07 0C5.5 0 .16 5.33.16 11.9c0 2.1.55 4.16 1.6 5.97L0 24l6.31-1.65a11.9 11.9 0 0 0 5.76 1.47h.01c6.57 0 11.9-5.33 11.9-11.9 0-3.18-1.24-6.17-3.46-8.44Zm-8.45 18.3h-.01a9.87 9.87 0 0 1-5.04-1.38l-.36-.22-3.74.98 1-3.65-.24-.38a9.86 9.86 0 0 1-1.5-5.26c0-5.45 4.44-9.88 9.9-9.88a9.82 9.82 0 0 1 7 2.9 9.82 9.82 0 0 1 2.9 7c0 5.45-4.44 9.89-9.88 9.89Z"/>
        </svg>
        Hablar con soporte por WhatsApp
      </a>
    </section>

  </main>

  <Footer />
</Layout>
