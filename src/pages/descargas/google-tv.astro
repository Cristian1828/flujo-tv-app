---
import { site, waLink } from '../../config/site';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const waInstall = waLink('Hola, necesito ayuda para instalar Flujo TV en mi Google TV.');
const waBuy     = waLink('Hola, quiero comprar Flujo TV para Google TV.');

const pageTitle    = 'Cómo Instalar Flujo TV en Google TV y Chromecast | Tutorial y Manual Oficial 2026';
const pageDesc     = 'Tutorial oficial para instalar Flujo TV en Google TV: Chromecast, Sony, TCL y Hisense. Manual paso a paso con video, activación asegurada y soporte garantizado 24/7. Guía actualizada 2026.';
const pageKeywords = 'instalar Flujo TV Google TV, tutorial Flujo TV Chromecast, manual instalacion Flujo TV Google TV, como instalar Flujo TV en Chromecast, Flujo TV Google TV 2026, guia oficial Google TV Flujo TV, activar Flujo TV Chromecast, Sony Google TV Flujo TV, TCL Google TV streaming, descargar Flujo TV Google TV';
const canonical    = `${site.canonical}/descargas/google-tv`;

// ── PASOS DE INSTALACIÓN ───────────────────────────────────────────
const steps = [
  {
    n: '01',
    title: 'Confirma que tu dispositivo tiene Google TV',
    body: 'Google TV es el sistema operativo de los Chromecast con Google TV y algunos Sony, TCL y Hisense recientes. La pantalla de inicio de Google TV tiene el buscador de Google en la parte superior.',
    tip: 'Si el menú principal muestra filas de contenido personalizado y recomendaciones, tienes Google TV.',
  },
  {
    n: '02',
    title: 'Habilita la instalación de fuentes desconocidas',
    body: 'Ve a Ajustes → Aplicaciones → Seguridad & Restricciones → Aplicaciones de fuentes desconocidas → Actívala.',
    tip: 'Este paso es necesario porque Flujo TV se instala fuera de Google Play Store.',
  },
  {
    n: '03',
    title: 'Descarga la aplicación Downloader',
    body: 'Abre Google Play Store · busca "Downloader by AFTVnews" · instala la app (es gratuita y oficial, ícono naranja).',
    tip: null,
  },
  {
    n: '04',
    title: 'Introduce el código de instalación',
    body: 'Abre Downloader, selecciona la barra de URL e introduce el código: 9249124. Presiona "Go" para iniciar la descarga del APK de Flujo TV.',
    tip: 'Si el código falla o está desactualizado, escríbenos y te enviamos el enlace directo.',
    highlight: true,
    highlightLabel: 'Código Downloader',
    highlightValue: '9249124',
  },
  {
    n: '05',
    title: 'Instala el archivo descargado',
    body: 'Cuando se complete la descarga, Downloader mostrará la pantalla de instalación. Selecciona "Instalar" y espera que finalice.',
    tip: null,
  },
  {
    n: '06',
    title: 'Inicia sesión con tus datos de acceso',
    body: 'Abre Flujo TV desde el menú de aplicaciones e introduce el usuario y contraseña que recibiste al activar tu plan.',
    tip: 'Si no ves la app en el menú principal, navega a "Tus aplicaciones" o "Apps" dentro de Google TV.',
  },
];

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'Cómo instalar Flujo TV en Google TV',
  description: pageDesc,
  image: `${site.canonical}/logo_flujo.webp`,
  totalTime: 'PT5M',
  supply: [
    { '@type': 'HowToSupply', name: 'Dispositivo Google TV (Chromecast, Sony, TCL, Hisense)' },
    { '@type': 'HowToSupply', name: 'Conexión a internet estable' },
    { '@type': 'HowToSupply', name: 'Cuenta activa de Flujo TV' },
  ],
  tool: [
    { '@type': 'HowToTool', name: 'Aplicación Downloader by AFTVnews' },
  ],
  step: steps.map((s, i) => ({
    '@type': 'HowToStep',
    position: i + 1,
    name: s.title,
    text: s.body,
    url: `${canonical}#paso-${s.n}`,
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio',     item: site.canonical },
    { '@type': 'ListItem', position: 2, name: 'Descargas',  item: `${site.canonical}/descargas/` },
    { '@type': 'ListItem', position: 3, name: 'Google TV',  item: canonical },
  ],
};
---

<Layout title={pageTitle} description={pageDesc} keywords={pageKeywords}>
  <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />

  <Header />

  <main class="min-h-screen bg-gradient-to-b from-slate-50 to-white pt-24 pb-20">

    <!-- ── Breadcrumb ───────────────────────────────────────────── -->
    <nav aria-label="Ruta de navegación" class="mx-auto max-w-6xl px-4 mb-6">
      <ol class="flex flex-wrap items-center gap-2 text-sm text-slate-900/55">
        <li><a href="/" class="hover:text-slate-900 transition">Inicio</a></li>
        <li aria-hidden="true"><span class="select-none">›</span></li>
        <li><a href="/descargas/" class="hover:text-slate-900 transition">Descargas</a></li>
        <li aria-hidden="true"><span class="select-none">›</span></li>
        <li class="text-slate-900 font-medium" aria-current="page">Google TV</li>
      </ol>
    </nav>

    <!-- ── Page hero ─────────────────────────────────────────────── -->
    <section class="mx-auto max-w-6xl px-4 mb-14">
      <div class="rounded-[2.5rem] border border-slate-900/8 bg-white shadow-soft overflow-hidden">
        <!-- accent bar -->
        <div class="h-1 w-full" style="background: linear-gradient(90deg, #f97316 0%, #0f172a 60%, #f97316 100%); opacity: 0.7;"></div>

        <div class="px-8 py-10 sm:px-14 sm:py-12 flex flex-col lg:flex-row items-center gap-10">
          <div class="flex-1 text-center lg:text-left">
            <div class="inline-flex items-center gap-2 rounded-full border border-slate-900/10 bg-slate-50 px-4 py-1.5 text-xs font-bold uppercase tracking-widest text-slate-900/60 mb-5">
              <span class="h-2 w-2 rounded-full bg-orange-400 inline-block animate-pulse"></span>
              Tutorial &amp; Manual oficial · Google TV y Chromecast
            </div>

            <h1 class="text-3xl sm:text-4xl lg:text-5xl font-black text-slate-900 tracking-tight leading-[1.08]">
              Instala <span class="text-orange-500">Flujo TV</span><br />
              en Google TV y Chromecast
            </h1>
            <p class="mt-4 max-w-2xl text-slate-900/65 text-base sm:text-lg leading-relaxed">
              Compatible con Chromecast con Google TV, Sony, TCL y Hisense. Tutorial completo con video, activación asegurada y soporte garantizado.
            </p>

            <!-- Compatible devices chips -->
            <div class="mt-5 flex flex-wrap justify-center lg:justify-start gap-2">
              {['Chromecast', 'Sony Bravia', 'TCL', 'Hisense', 'Sharp AQUOS'].map(d => (
                <span class="rounded-full border border-slate-900/10 bg-slate-50 px-3 py-1 text-xs font-medium text-slate-900/65">{d}</span>
              ))}
            </div>

            <div class="mt-8 flex flex-wrap justify-center lg:justify-start gap-3">
              <a
                href="#pasos"
                class="inline-flex items-center gap-2 rounded-xl bg-slate-900 hover:bg-slate-800 px-6 py-3 text-sm font-bold text-white transition shadow-lg shadow-slate-900/20"
              >
                <svg viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4" aria-hidden="true"><path fill-rule="evenodd" d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16ZM9.555 7.168A1 1 0 0 0 8 8v4a1 1 0 0 0 1.555.832l3-2a1 1 0 0 0 0-1.664l-3-2Z" clip-rule="evenodd"/></svg>
                Ver pasos de instalación
              </a>
              <a
                href={waInstall}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 rounded-xl border border-slate-900/15 bg-slate-50 hover:bg-slate-100 px-6 py-3 text-sm font-semibold text-slate-900 transition"
              >
                Necesito ayuda →
              </a>
            </div>
          </div>

          <!-- quick specs -->
          <div class="grid grid-cols-3 lg:grid-cols-1 gap-3 shrink-0 lg:min-w-[150px]">
            {[
              { v: '5 min', l: 'Duración' },
              { v: 'Fácil', l: 'Nivel' },
              { v: '2026', l: 'Actualizada' },
            ].map(s => (
              <div class="rounded-2xl border border-slate-900/8 bg-slate-50 px-4 py-3 text-center">
                <div class="text-xl font-black text-slate-900">{s.v}</div>
                <div class="text-[11px] uppercase tracking-wider text-slate-900/45 mt-0.5">{s.l}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ── Video ─────────────────────────────────────────────────── -->
    <section class="mx-auto max-w-6xl px-4 mb-14">
      <div class="rounded-[2rem] border border-slate-900/8 bg-white shadow-soft overflow-hidden">
        <div class="px-6 py-5 border-b border-slate-900/5">
          <h2 class="text-xl font-extrabold text-slate-900">Video tutorial — Google TV y Chromecast</h2>
          <p class="text-sm text-slate-900/55 mt-0.5">Instalación paso a paso en Google TV (Chromecast, Sony, TCL, Hisense)</p>
        </div>

        <!-- Video Wistia: Tutorial instalación Flujo TV en Google TV y Chromecast -->
        <div class="w-full">
          <Fragment set:html={`
            <script src="https://fast.wistia.com/player.js" async><\/script>
            <script src="https://fast.wistia.com/embed/xw1xedf4qg.js" async type="module"><\/script>
            <style>wistia-player[media-id='xw1xedf4qg']:not(:defined){background:center/contain no-repeat url('https://fast.wistia.com/embed/medias/xw1xedf4qg/swatch');display:block;filter:blur(5px);padding-top:56.25%;}</style>
            <wistia-player media-id="xw1xedf4qg" aspect="1.7777777777777777"></wistia-player>
          `} />
        </div>

        <div class="px-6 py-4 bg-slate-50 border-t border-slate-900/5">
          <p class="text-sm text-slate-900/80 font-medium">
            <strong>Código Downloader:</strong>
            <span class="ml-2 font-mono font-black text-slate-900 tracking-widest text-base">9249124</span>
            — Escríbelo exactamente como aparece en el video.
          </p>
        </div>
      </div>
    </section>

    <!-- ── Steps ─────────────────────────────────────────────────── -->
    <section id="pasos" class="mx-auto max-w-6xl px-4 mb-14" aria-labelledby="steps-heading">
      <h2 id="steps-heading" class="text-2xl sm:text-3xl font-black text-slate-900 tracking-tight mb-2">
        Pasos de instalación
      </h2>
      <p class="text-slate-900/55 mb-10 max-w-2xl text-sm">
        Sigue cada paso en orden. Si en algún momento te bloqueas, escríbenos.
      </p>

      <ol class="space-y-5">
        {steps.map((s) => (
          <li id={`paso-${s.n}`} class="relative flex gap-5 rounded-[2rem] border border-slate-900/8 bg-white shadow-soft p-6 sm:p-8">
            <!-- step number -->
            <div class="shrink-0 flex h-12 w-12 items-center justify-center rounded-2xl bg-[#4285F4]/10 border border-[#4285F4]/20 font-black text-[#4285F4] text-sm">
              {s.n}
            </div>

            <div class="flex-1 min-w-0">
              <h3 class="font-extrabold text-slate-900 text-base sm:text-lg leading-tight">{s.title}</h3>
              <p class="mt-2 text-sm sm:text-base text-slate-900/65 leading-relaxed">{s.body}</p>

              {s.highlight && (
                <div class="mt-4 inline-flex items-center gap-3 rounded-2xl border border-blue-200 bg-blue-50 px-5 py-3">
                  <span class="text-xs font-bold text-blue-700 uppercase tracking-wide">{s.highlightLabel}:</span>
                  <span class="font-mono font-black text-blue-900 text-xl tracking-[0.25em]">{s.highlightValue}</span>
                </div>
              )}

              {s.tip && (
                <div class="mt-3 flex gap-2 text-sm text-slate-900/50">
                  <span class="shrink-0 text-[#4285F4] font-bold">↳</span>
                  <span>{s.tip}</span>
                </div>
              )}
            </div>
          </li>
        ))}
      </ol>
    </section>

    <!-- ── Compatibility note ────────────────────────────────────── -->
    <section class="mx-auto max-w-6xl px-4 mb-12">
      <div class="rounded-[2rem] border border-slate-900/8 bg-slate-50 px-8 py-8">
        <h2 class="text-lg font-extrabold text-slate-900 mb-6">Dispositivos Google TV compatibles</h2>
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
          {[
            { brand: 'Chromecast', models: 'Google TV 4K, Google TV HD, Google TV 4K Max', icon: '📡' },
            { brand: 'Sony', models: 'Bravia XR, X80K, X90K, X95K y modelos con Google TV posteriores a 2021', icon: '📺' },
            { brand: 'TCL', models: 'Serie C745, C835, Q735 y QLED con Google TV integrado', icon: '📺' },
            { brand: 'Hisense', models: 'Serie U6H, U7H, U8H y modelos ULED con Google TV', icon: '📺' },
          ].map(d => (
            <div class="flex gap-3">
              <span class="text-xl shrink-0 mt-0.5">{d.icon}</span>
              <div>
                <div class="font-extrabold text-slate-900 text-sm">{d.brand}</div>
                <p class="mt-0.5 text-xs text-slate-900/55 leading-relaxed">{d.models}</p>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-6 rounded-xl border border-amber-200 bg-amber-50 p-4">
          <p class="text-sm text-amber-800">
            <strong>¿No sabes si tu TV tiene Google TV?</strong> Ve a la pantalla de inicio: si ves filas de contenido personalizado y el buscador de Google arriba, tienes Google TV. Si tienes dudas, escríbenos y te confirmamos.
          </p>
        </div>
      </div>
    </section>

    <!-- ── CTA ───────────────────────────────────────────────────── -->
    <section class="mx-auto max-w-6xl px-4 mb-12">
      <div class="rounded-[2rem] bg-slate-900 px-8 py-10 flex flex-col sm:flex-row items-center justify-between gap-6">
        <div>
          <p class="text-white/55 text-xs font-bold uppercase tracking-widest mb-1">¿Aún no tienes cuenta?</p>
          <h2 class="text-xl sm:text-2xl font-black text-white">Activa Flujo TV hoy desde <span class="text-orange-400">$9 USD</span></h2>
          <p class="mt-1 text-white/55 text-sm">Activación en minutos. Sin contratos. Soporte garantizado.</p>
        </div>
        <div class="flex flex-wrap gap-3 shrink-0">
          <a
            href={waBuy}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-xl bg-orange-500 hover:bg-orange-400 px-6 py-3 text-sm font-bold text-white transition"
          >
            Comprar ahora →
          </a>
          <a
            href={waInstall}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-xl border border-white/20 bg-white/8 hover:bg-white/15 px-6 py-3 text-sm font-semibold text-white transition"
          >
            Necesito ayuda
          </a>
        </div>
      </div>
    </section>

    <!-- ── Related ───────────────────────────────────────────────── -->
    <section class="mx-auto max-w-6xl px-4" aria-labelledby="related-heading">
      <h2 id="related-heading" class="text-lg font-extrabold text-slate-900 mb-4">Otras guías de instalación</h2>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <a
          href="/descargas/android-tv"
          class="flex items-center gap-4 rounded-2xl border border-slate-900/8 bg-white shadow-soft hover:shadow-md hover:-translate-y-0.5 p-5 transition focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange-400"
        >
          <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-[#3DDC84]/10 shrink-0">
            <svg viewBox="0 0 24 24" fill="#3DDC84" class="h-6 w-6" aria-hidden="true"><path d="M17.523 15.341a.5.5 0 0 0 .5-.5c0-.277-.223-.5-.5-.5H6.477a.5.5 0 0 0 0 1h11.046ZM4.5 6.5h15C20.88 6.5 22 7.62 22 8.899v5.202C22 15.38 20.88 16.5 19.5 16.5h-15C3.12 16.5 2 15.38 2 14.101V8.9C2 7.619 3.12 6.5 4.5 6.5Z"/></svg>
          </div>
          <div>
            <div class="font-extrabold text-slate-900 text-sm">Android TV</div>
            <div class="text-xs text-slate-900/50 mt-0.5">TV Box y dispositivos Android TV</div>
          </div>
          <svg viewBox="0 0 20 20" fill="none" class="h-4 w-4 text-slate-900/30 ml-auto shrink-0" stroke="currentColor" stroke-width="2"><path d="M7 5l5 5-5 5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>

        <a
          href="/descargas/"
          class="flex items-center gap-4 rounded-2xl border border-slate-900/8 bg-white shadow-soft hover:shadow-md hover:-translate-y-0.5 p-5 transition focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange-400"
        >
          <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-slate-900/5 shrink-0">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5 text-slate-900/60" aria-hidden="true">
              <path d="M3 9h18v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V9ZM3 9V6a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v3"/>
            </svg>
          </div>
          <div>
            <div class="font-extrabold text-slate-900 text-sm">Ver todas las guías</div>
            <div class="text-xs text-slate-900/50 mt-0.5">Todos los dispositivos compatibles</div>
          </div>
          <svg viewBox="0 0 20 20" fill="none" class="h-4 w-4 text-slate-900/30 ml-auto shrink-0" stroke="currentColor" stroke-width="2"><path d="M7 5l5 5-5 5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </section>

  </main>

  <Footer />
</Layout>
